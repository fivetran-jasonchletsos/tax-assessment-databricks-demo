# ============================================================
# Owner: jason_chletsos
# Project: Allegheny County Tax Assessment Application
# Environment Variables Template
# ============================================================

# Databricks Connection (reusing credentials from pokemon-app)
# These credentials are stored in AWS Secrets Manager:
# - pokemon-app/databricks-token
# - pokemon-app/databricks-http-path
DATABRICKS_HOST=dbc-c48d38b1-67f3.cloud.databricks.com
DATABRICKS_HTTP_PATH=<retrieve-from-aws-secrets-manager>
DATABRICKS_TOKEN=<retrieve-from-aws-secrets-manager>

# Databricks Catalog and Schemas
DATABRICKS_CATALOG=jason_chletsos_allegheny_tax
DATABRICKS_STAGING_SCHEMA=jason_chletsos_staging
DATABRICKS_MARTS_SCHEMA=jason_chletsos_marts

# Fivetran Configuration (credentials stored in AWS Secrets Manager)
# Retrieve from: pokemon-app/fivetran-api-key and pokemon-app/fivetran-api-secret
FIVETRAN_DESTINATION=jason_chletsos_databricks
FIVETRAN_CONNECTOR_WPRDC=jason_chletsos_wprdc
FIVETRAN_CONNECTOR_AC=jason_chletsos_alleghenyre
FIVETRAN_API_KEY=<retrieve-from-aws-secrets-manager>
FIVETRAN_API_SECRET=<retrieve-from-aws-secrets-manager>

# Application Settings
APP_PORT=3000
API_PORT=8000
NODE_ENV=development

# API Configuration
API_BASE_URL=http://localhost:8000/api
